GATEWAY_JWT_SECRET=
# Generate once (for example: openssl rand -base64 32) and keep it persistent.
GATEWAY_ENCRYPTION_KEY=
# Only set during an encryption-key rotation; remove after a successful start.
GATEWAY_PREVIOUS_ENCRYPTION_KEY=
REDIS_PASSWORD=changeme

# PostgreSQL deployment: local starts compose.psql.yml; remote uses DB_HOST.
DB_DEPLOYMENT=local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aigateway
DB_USER=postgres
DB_PASSWORD=postgres123

# OTLP trace export endpoint (gRPC).  Leave empty to disable.
OTLP_ENDPOINT=http://localhost:4317
